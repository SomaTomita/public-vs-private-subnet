# ==============================================================================
# terraform.tfvars — Lab Configuration
# ==============================================================================
# 1. Copy this file:  cp terraform.tfvars.example terraform.tfvars
# 2. Fill in the REQUIRED values below
# 3. Run:  terraform apply -var="config_mode=public"
# ==============================================================================

# ------------------------------------------------------------------------------
# Required
# ------------------------------------------------------------------------------

config_mode  = "public"                 # "public" (Config A) or "private" (Config B)
my_ip        = "203.0.113.50/32"        # Your public IP in CIDR — run: curl -s ifconfig.me
db_password  = "CHANGE_ME_before_apply" # RDS master password (min 8 chars, MUST change)
budget_email = "your-email@example.com" # Budget alert notification email

# ------------------------------------------------------------------------------
# Optional (uncomment to override defaults)
# ------------------------------------------------------------------------------

# aws_region        = "ap-northeast-1"  # AWS region
# instance_type     = "t2.micro"        # EC2 instance type (Free Tier)
# db_instance_class = "db.t3.micro"     # RDS instance class (Free Tier w/ Single-AZ)
# budget_limit      = 5                 # Monthly budget alert threshold (USD)
